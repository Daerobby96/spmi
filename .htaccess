# ==============================================================
#  Root .htaccess - SPMI App Security Hardening
#  Apache 2.4 Syntax
# ==============================================================

# ---------------------------------------------------------------
# 1. Mencegah directory listing
# ---------------------------------------------------------------
Options -Indexes -MultiViews

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---------------------------------------------------------------
    # 2. Blokir akses ke file-file sensitif (Apache 2.4 syntax)
    # ---------------------------------------------------------------
    <FilesMatch "(\.env|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|vite\.config\.js|\.htpasswd|Dockerfile|docker-compose\.yml)$">
        Require all denied
    </FilesMatch>

    # ---------------------------------------------------------------
    # 3. Blokir akses ke folder-folder sistem Laravel
    # ---------------------------------------------------------------
    RewriteRule ^(\.git|storage|tests|app|bootstrap|config|database|resources|vendor)(/|$) - [F,L]

    # ---------------------------------------------------------------
    # 4. Blokir file yang diawali dengan titik (hidden files)
    # ---------------------------------------------------------------
    RewriteRule (^\..*) - [F,L]

    # ---------------------------------------------------------------
    # 5. Redirect semua request ke folder public
    # ---------------------------------------------------------------
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
